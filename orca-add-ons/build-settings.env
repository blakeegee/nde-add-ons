# Used by `npm run build:addon`.
# `npm run build` builds every add-on in addon-profiles.json.
# Add your first add-on to addon-profiles.json, then set ADDON_KEY here
# when you want to build only that add-on locally.
# ADDON_KEY=orca-test-banner

# Optional overrides for single-add-on packaging and distribution.
# BUILD_NAME=orca-test-banner
# REMOTE_NAME=orcaTestBanner
# PACKAGE_NAME=orca-test-banner
